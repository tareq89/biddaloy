# beton-boi environment variables
# Copy this to .env and fill in real values.

# Database (PostgreSQL connection string)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/betonboi

# Application
NODE_ENV=production
PORT=3000

# Authentication
JWT_SECRET=change-me-to-a-random-string

# Optional: custom app settings
# APP_NAME=beton-boi
# LOG_LEVEL=debug

# Seed admin password (used by "yarn seed")
# SEED_ADMIN_PASSWORD=change-me-admin-password-123

# TypeORM: set to "true" to auto-sync schema from entities (dev only — never use in prod)
# DB_SYNCHRONIZE=false

# Destructive operations: set to "true" to confirm db:clear / db:reset
# DB_DESTROY_CONFIRM=false