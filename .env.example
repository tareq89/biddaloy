# Copy to .env and fill in real values: cp .env.example .env
# docker-compose reads this file automatically.

POSTGRES_USER=betonboi
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=betonboi

# Derived automatically inside the app container as:
# postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
