{
  "name": "@beton-boi/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --include='src/**/*.spec.ts' --exclude='src/**/*.integration.spec.ts' --exclude='src/**/*.e2e-spec.ts'",
    "test:integration": "vitest run --include='src/**/*.integration.spec.ts' --reporter=verbose",
    "test:e2e": "vitest run --include='src/**/*.e2e-spec.ts' --reporter=verbose",
    "test:file": "vitest run",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "db:clear": "ts-node src/scripts/db-clear.ts",
    "db:reset": "ts-node src/scripts/db-reset.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11",
    "@nestjs/typeorm": "^11",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "typeorm": "^0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/testing": "^11",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "vitest": "^3"
  }
}
